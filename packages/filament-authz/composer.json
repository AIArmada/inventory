{
  "name": "aiarmada/filament-authz",
  "version": "1.0.0",
  "description": "Filament v5 permissions suite powered by Spatie laravel-permission with multi-guard, panel-aware gating, and admin UX.",
  "license": "MIT",
  "homepage": "https://github.com/aiarmada/commerce",
  "support": {
    "issues": "https://github.com/aiarmada/commerce/issues",
    "source": "https://github.com/aiarmada/commerce"
  },
  "require": {
    "aiarmada/commerce-support": "self.version",
    "filament/filament": "^5.0",
    "spatie/laravel-permission": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "AIArmada\\FilamentAuthz\\": "src/",
      "AIArmada\\FilamentAuthz\\Database\\Factories\\": "database/factories/",
      "AIArmada\\FilamentAuthz\\Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "AIArmada\\FilamentAuthz\\FilamentAuthzServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}