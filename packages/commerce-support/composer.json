{
    "name": "aiarmada/commerce-support",
    "version": "1.0.0",
    "description": "Core helper methods and foundation code for all AIArmada Commerce packages.",
    "license": "MIT",
    "homepage": "https://github.com/aiarmada/commerce",
    "support": {
        "issues": "https://github.com/aiarmada/commerce/issues",
        "source": "https://github.com/aiarmada/commerce"
    },
    "require": {
        "php": "^8.4",
        "akaunting/laravel-money": "^6.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0",
        "lorisleiva/laravel-actions": "^2.9",
        "nunomaduro/essentials": "^1.0",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-data": "^4.18",
        "spatie/laravel-health": "^1.34",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.92",
        "spatie/laravel-settings": "^3.6",
        "spatie/laravel-sluggable": "^3.7",
        "spatie/laravel-model-states": "^2.0",
        "spatie/laravel-tags": "^4.2",
        "spatie/laravel-webhook-client": "^3.4"
    },
    "suggest": {
        "laravel/octane": "Required for high-performance Octane support"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "AIArmada\\CommerceSupport\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\CommerceSupport\\SupportServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}